# Copy this file to `.env` before running `docker compose`.
# Keep only placeholder values here. Never commit real secrets.

# Public domains exposed through Traefik.
TRAEFIK_DOMAIN=example.com
TRAEFIK_API_DOMAIN=
LETSENCRYPT_EMAIL=admin@example.com

# Backend application port inside the container.
PORT=5000

# Frontend build-time variables for the Vite app.
# Use the public HTTPS URL that the browser should call for the backend API.
VITE_API_URL=https://example.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Backend Supabase connection.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Backend LLM configuration.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
LLM_TIMEOUT_MS=30000

# OpenAI provider credentials used by the default LLM adapter.
OPENAI_API_KEY=
# Optional n8n webhook for forwarding contact form submissions.
N8N_CONTACT_WEBHOOK_URL=
# Optional aliases when LLM_* values are not set.
OPENAI_MODEL=
OPENAI_TEMPERATURE=
OPENAI_MAX_TOKENS=
