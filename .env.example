# Root-level reference for local development.
# Real runtime .env files should be created in frontend/ and backend/.

# Frontend API base URL
VITE_API_URL=http://localhost:5000

# Backend
PORT=5000
SUPABASE_URL=
SUPABASE_ANON_KEY=

# LLM (backend)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
LLM_TIMEOUT_MS=30000
OPENAI_API_KEY=
# Optional aliases (LLM_* takes precedence)
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=700
